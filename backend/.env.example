# Database Configuration
# For production/docker, use the relevant PostgreSQL service name (e.g. postgres-db)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/school_sync

# Security & JWT Configuration
JWT_SECRET=change_me_to_a_secure_random_string_in_production_32_chars_or_more
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=test@example.com
SMTP_PASSWORD=password123
SMTP_FROM_EMAIL=no-reply@schoolsync.com

# Celery & Redis
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# Default Initial Administrator Configuration
INITIAL_ADMIN_EMAIL=admin@schoolsync.com
INITIAL_ADMIN_PASSWORD=AdminPassword123
INITIAL_ADMIN_TEACHER_ID=ADM001
INITIAL_ADMIN_NAME=System Administrator
