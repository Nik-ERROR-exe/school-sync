# Database Configuration
# For production/docker, use the relevant PostgreSQL service name (e.g. postgres-db)
DATABASE_URL=

# Security & JWT Configuration
JWT_SECRET=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

# SMTP Configuration for Email Notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Celery & Redis
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# Default Initial Administrator Configuration
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_TEACHER_ID=
INITIAL_ADMIN_NAME=
